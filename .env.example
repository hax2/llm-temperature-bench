# Required for judging. The runner also accepts GOOGLE_API_KEY for compatibility.
GEMINI_API_KEY=

# Required for gated Llama and Gemma repositories after accepting their licenses.
HF_TOKEN=

# Optional override. If omitted, the runner automatically prefers a writable
# /home/jovyan cache when it has more free space than the default home cache.
# HF_HOME=/mnt/models/huggingface
